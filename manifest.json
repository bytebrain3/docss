{
  "manifest_version": 3,
  "name": "DocHopper",
  "description": "Instantly jump between documentation sites (MDN, npm, GitHub, Tailwind, and more) while preserving your exact reading context.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "DocHopper",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "description": "Open DocHopper popup"
    },
    "jump-palette": {
      "description": "Open DocHopper jump palette",
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      }
    },
    "return-context": {
      "description": "Return to previous DocHopper context",
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      }
    }
  },
  "options_page": "options/options.html"
}
